{
  "name": "grade6-virtual-lab-phaser",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,blue \"npm:dev --workspace server\" \"npm:dev --workspace client\"",
    "seed": "npm --workspace server run seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}